# ============================================
# Конфигурация GIBDD Telegram-бота
# Скопируйте этот файл как .env и заполните значения
# ============================================

# --- Telegram Bot ---
# Получите токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=8839210662:AAGkn2CvMUUhFfn2RLCU1U-WHXQQo72T0iA

# --- Сеть ---
# Таймаут запросов к API stat.gibdd.ru (в секундах).
# При больших выборках API может отвечать медленно. Рекомендуется 60-120.
TARGET_API_TIMEOUT=120

# Прокси (если ваш корпоративный сети использует прокси)
# Оставьте пустым, если прокси не нужен
HTTP_PROXY=
HTTPS_PROXY=

# --- Доступ (опционально) ---
# Список Telegram ID пользователей через запятую, которым разрешено пользоваться ботом.
# Оставьте пустым, чтобы разрешить доступ всем.
ALLOWED_USER_IDS=

# --- Логирование ---
# Уровни: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
